		}
		{
			dependencies: ["2874DFAF44DC8655"]
			description: ["You might be wondering how to get some of the Chiseled blocks. Well, you can craft the ones in the quest window and then you need to use Stonecutter from Minecraft to change them."]
			id: "2E08E6E0556DF840"
			tasks: [
				{
