		}
		{
			description: [
				"You kinda need to get helium for Nobelium, and there are 2 ways to get it:"
				""
				"a) This is easy to do but it yields low Helium"
				"1) Craft Void Gas Extractor"
				"2) Start extracting Natural Gasses and as a byproduct you get a bit of Helium"
				""
				"b) This gets you a lot of Helium but its more complicated:"
				"1) Get T1 rocket and visit Moon"
				"2) On moon you can get Desh (find 1 ore and then use mod Scannable to find others)"
				"3) While searching for Desh, get Moon Cobblestone, which you can smelt to stone"
				"4) Make a End Portal Frame block out of Moon Stone and Eye of Ender"
				"5) You're in the End"
				"6) Get Ender Air and distill it"
			]
			id: "1D668061E99D565B"
			rewards: [{
				id: "12B51A53C3C1BFDE"
				item: "kubejs:cc"
				type: "item"
